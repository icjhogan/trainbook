# Supabase — get these from your project's API settings
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Anthropic — for workout extraction (Claude Sonnet vision) and AI chat
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key

# OpenAI — server-only; for workout embeddings (text-embedding-3-small @ 1024 dims),
# powering the chat assistant's semantic search. NEVER expose to the client (no NEXT_PUBLIC_).
# Must be set in Production AND Preview (Vercel env vars are per-environment).
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-key

# Optional — durable AI-spend rate limiting across serverless instances.
# Without these, the app falls back to an in-process per-instance limiter (fine for
# single-user). Set both to upgrade lib/rate-limit.ts to an Upstash Redis store.
# https://upstash.com/docs/redis
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token
